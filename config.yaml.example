# 실행 설정 예시. 복사해서 config.yaml로 만들고 환경에 맞게 수정한다.
#   cp config.yaml.example config.yaml
# DB 비밀번호는 여기 적지 않고 password_env가 가리키는 환경변수에서 읽는다.

encoding: Shift_JIS

paths:
  asis_input_dir: ./samples/asis/input
  asis_output_dir: ./samples/asis/output
  tobe_input_dir: ./out/tobe_input          # 파일 입력(야간 배치) raw 복사 대상 (D-021, T2-3부터 사용)
  tobe_output_dir: ./out/tobe_output
  report_dir: ./out/reports
  definition_file: ./test_definition.yaml   # 셸별 정의 파일 (D-021, T2-3부터 사용)

database:
  host: localhost
  port: 5432
  dbname: compare_proto
  user: postgres
  password_env: POSTGRES_PASSWORD   # 이 환경변수에서 비밀번호를 읽음

batch:
  type: stub                        # 'stub' | 'netcobol' (추후 확장)
  stub_dir: ./stub_batch            # 셸별 stub(run_batch_db.py / run_batch_file.py)은 정의 파일 execution.shell_program이 선택 (D-022)
  timeout_seconds: 60

shells:
  range: [1, 10]    # 정의 파일(test_definition.yaml) 폴백. 정의 파일이 있으면 그쪽 셸 목록이 우선.
  # 또는 ids: ["001", "003", "007"]

output:
  cli_color: true
  cli_verbose: false
  report_with_bom: true
