# complete 데모셋 설정 — ★커밋되는 완전판 예시(데모가 바로 도는 정본 템플릿).
#   사용:  cp samples/complete/config.yaml.example samples/complete/config.yaml
#   그다음: export POSTGRES_PASSWORD=<자기 DB 비번>  (평문 금지 — env로만)
#   그다음: PGPORT=<포트> ./samples/complete/run_demo.sh
# ★실제 config.yaml은 .gitignore(자격 보호) — 이 example만 커밋된다. 비밀번호는 절대 여기 적지 않는다.
# 단일 정본 데모셋(파일흐름 22 + DB 2 = 24 체크리스트). 경로는 이 파일 기준 상대.
encoding: Shift_JIS

paths:
  asis_input_dir: ./asis/input
  asis_output_dir: ./asis/output
  tobe_input_dir: ./tobe/in
  tobe_output_dir: ./tobe/output
  report_dir: ./reports
  definition_file: ./test_definition.yaml

# DB CK(019·020)용. 파일흐름 22건은 DB 불요. 데모 박스 dc-pg는 5433(자기 환경에 맞게 수정).
# ★password_env가 가리키는 환경변수에서 비밀번호를 읽는다 — 여기 평문 금지(모델 A).
database:
  host: localhost
  port: 5433
  dbname: compare_proto
  user: postgres
  password_env: POSTGRES_PASSWORD

batch:
  type: stub
  timeout_seconds: 60
  # 업무별 배치 환경(키=shell_group). ★lint 태그 전용 — runner는 base_dir로 경로해석 안 함(실연결 보류).
  # 정의 파일의 shell_group 값은 반드시 여기 등록돼 있어야 프리플라이트를 통과한다(D-040).
  groups:
    業務A: { base_dir: ./mock_linux/opt/migsys/業務A }
    業務B: { base_dir: ./mock_linux/opt/migsys/業務B }
    業務C: { base_dir: ./mock_linux/opt/migsys/業務C }
    業務D: { base_dir: ./mock_linux/opt/migsys/業務D }

shells:
  range: [1, 1]   # 정의 파일(test_definition.yaml)이 정본 — 이 폴백 미사용.

output:
  cli_color: true
  cli_verbose: false
  report_with_bom: true
